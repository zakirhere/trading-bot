ALPACA_API_KEY_ID=PASTE_PAPER_KEY_ID
ALPACA_API_SECRET_KEY=PASTE_PAPER_SECRET_KEY
ALPACA_BASE_URL=https://paper-api.alpaca.markets
TRADEBOT_LIVE=0
# Required only for live trading:
# TRADEBOT_CONFIRM_LIVE_ALPACA=I_UNDERSTAND_THIS_USES_REAL_MONEY

# Optional Slack notifications:
# NOTIFY_PROVIDER=slack
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional dashboard auth override. If unset, a token is generated at
# ~/.tradebot/dashboard_token on first service start.
# DASHBOARD_TOKEN=replace-with-a-long-random-token

# Dashboard bind address. Keep localhost by default. For private Tailscale
# access, set SERVICE_HOST to this Mac's Tailscale 100.x.y.z address.
# SERVICE_HOST=127.0.0.1
# SERVICE_PORT=8787

# Paper-only ICL strategy autorun. When enabled, the persistent service queues
# SPY ICL limit-credit spread entries at deterministic random market-hour slots.
# TRADEBOT_ICL_PAPER_AUTORUN=1

# Paper-only DCA strategy autorun. Queues SPY DCA limit-credit spread entries.
# TRADEBOT_DCA_PAPER_AUTORUN=1

# ORB stock strategy observe mode. Logs/notifies breakout signals only; it does
# not submit stock orders.
# TRADEBOT_ORB_OBSERVE=1
